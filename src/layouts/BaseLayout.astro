---
import { ClientRouter } from 'astro:transitions';
import CartDrawer from '../components/CartDrawer.jsx';
import Footer from '../components/Footer.astro';
import Navigation from '../components/Navigation.astro';
import '../index.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Eco Vibe | Sustainable Living',
  description = 'Eco Vibe — Sustainable living. Curated eco-friendly products for a conscious lifestyle.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#166534" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <ClientRouter />
  </head>
  <body>
    <Navigation transition:persist />
    <main>
      <slot />
    </main>
    <Footer />
    <CartDrawer client:idle transition:persist />
  </body>
</html>
